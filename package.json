{
  "name": "spwnr-registry",
  "version": "0.1.0",
  "type": "module",
  "description": "Community template registry snapshot for Spwnr subagents",
  "license": "MIT",
  "files": [
    "templates",
    "site",
    "scripts",
    "registry-index.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./registry-index.json": "./registry-index.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "validate:templates": "node ./scripts/validate-templates.mjs",
    "build:index": "node ./scripts/build-registry-index.mjs",
    "build:site": "node ./scripts/build-site.mjs",
    "build": "npm run build:index && npm run build:site"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  }
}
