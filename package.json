{
  "name": "@spwnr/registry",
  "version": "0.3.0",
  "type": "module",
  "description": "Community template registry snapshot for Spwnr subagents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cheong43/spwnr-registry.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.6.2",
  "files": [
    "templates",
    "site",
    "scripts",
    "registry-index.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./registry-index.json": "./registry-index.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "validate:templates": "node ./scripts/validate-templates.mjs",
    "build:index": "node ./scripts/build-registry-index.mjs",
    "build:site": "node ./scripts/build-site.mjs",
    "build": "npm run build:index && npm run build:site"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  }
}
